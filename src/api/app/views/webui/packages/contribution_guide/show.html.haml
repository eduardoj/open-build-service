- @pagetitle = "Contribution Guide of Package #{@package}"
- @pagetitle += " (inherited from project #{@project})" if @package.contribution_guide.blank?

.card
  = render(partial: 'webui/package/tabs', locals: { project: @project, package: @package })
  .card-body
    %h3.mb-4= @pagetitle
    = sanitize @package.contribution_guide.present? ? @package.contribution_guide : @project.contribution_guide
